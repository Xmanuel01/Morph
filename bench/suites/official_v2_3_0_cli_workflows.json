{
  "suite": "official_v2_3_0_cli_workflows",
  "description": "CLI workflow benchmark cases",
  "class": "cli_workflows",
  "cases": [
    {
      "id": "tokenizer_train_cli",
      "description": "Tokenizer training on deterministic fixture corpus",
      "enkai_command": [
        "${ENKAI_BIN}",
        "tokenizer-lite",
        "train",
        "bench/fixtures/tiny_corpus.txt",
        "bench/results/tokenizer_bench.json",
        "--vocab-size",
        "256",
        "--min-freq",
        "1",
        "--seed",
        "1337"
      ],
      "python_command": [
        "${PYTHON_EXE}",
        "bench/python/tokenizer_train_cli.py",
        "bench/fixtures/tiny_corpus.txt",
        "bench/results/tokenizer_bench.py.json",
        "--vocab-size",
        "256",
        "--min-freq",
        "1",
        "--seed",
        "1337"
      ],
      "equivalence": {
        "enkai_work_units": 1,
        "python_work_units": 1,
        "enkai_payload_bytes": 4096,
        "python_payload_bytes": 4096,
        "enkai_batching_mode": "cli_single_shot",
        "python_batching_mode": "cli_single_shot",
        "enkai_warmup_policy": "suite_default",
        "python_warmup_policy": "suite_default"
      }
    },
    {
      "id": "dataset_inspect_cli",
      "description": "Dataset inspect pass with deterministic batching",
      "enkai_command": [
        "${ENKAI_BIN}",
        "dataset-lite",
        "inspect",
        "bench/fixtures/tiny_corpus.txt",
        "bench/results/tokenizer_bench.json",
        "--seq-len",
        "8",
        "--batch-size",
        "4",
        "--seed",
        "1337",
        "--shuffle",
        "--output",
        "bench/results/dataset_bench.json"
      ],
      "python_command": [
        "${PYTHON_EXE}",
        "bench/python/dataset_inspect_cli.py",
        "bench/fixtures/tiny_corpus.txt",
        "bench/results/tokenizer_bench.py.json",
        "--seq-len",
        "8",
        "--batch-size",
        "4",
        "--seed",
        "1337",
        "--shuffle",
        "--output",
        "bench/results/dataset_bench.py.json"
      ],
      "equivalence": {
        "enkai_work_units": 1,
        "python_work_units": 1,
        "enkai_payload_bytes": 4096,
        "python_payload_bytes": 4096,
        "enkai_batching_mode": "cli_single_shot",
        "python_batching_mode": "cli_single_shot",
        "enkai_warmup_policy": "suite_default",
        "python_warmup_policy": "suite_default"
      }
    }
  ]
}
