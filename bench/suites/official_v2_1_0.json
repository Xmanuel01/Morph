{
  "suite": "official_v2_1_0",
  "description": "Official Enkai v2.1.0 benchmark suite (bounded claims)",
  "cases": [
    {
      "id": "numeric_kernel",
      "description": "Integer arithmetic loop throughput",
      "enkai_command": ["${ENKAI_BIN}", "run", "bench/enkai/kernel_numeric.enk"],
      "python_command": ["${PYTHON_EXE}", "bench/python/kernel_numeric.py"]
    },
    {
      "id": "json_kernel",
      "description": "JSON parse/stringify throughput",
      "enkai_command": ["${ENKAI_BIN}", "run", "bench/enkai/kernel_json.enk"],
      "python_command": ["${PYTHON_EXE}", "bench/python/kernel_json.py"]
    },
    {
      "id": "hash_kernel",
      "description": "SHA-256 throughput",
      "enkai_command": ["${ENKAI_BIN}", "run", "bench/enkai/kernel_hash.enk"],
      "python_command": ["${PYTHON_EXE}", "bench/python/kernel_hash.py"]
    },
    {
      "id": "train_step_kernel",
      "description": "Gradient-descent style training loop",
      "enkai_command": ["${ENKAI_BIN}", "run", "bench/enkai/kernel_train_step.enk"],
      "python_command": ["${PYTHON_EXE}", "bench/python/kernel_train_step.py"]
    },
    {
      "id": "inference_kernel",
      "description": "Autoregressive-style token loop",
      "enkai_command": ["${ENKAI_BIN}", "run", "bench/enkai/kernel_inference.enk"],
      "python_command": ["${PYTHON_EXE}", "bench/python/kernel_inference.py"]
    },
    {
      "id": "tokenizer_train_cli",
      "description": "Tokenizer training on deterministic fixture corpus",
      "enkai_command": ["${ENKAI_BIN}", "tokenizer-lite", "train", "bench/fixtures/tiny_corpus.txt", "bench/results/tokenizer_bench.json", "--vocab-size", "256", "--min-freq", "1", "--seed", "1337"],
      "python_command": ["${PYTHON_EXE}", "bench/python/tokenizer_train_cli.py", "bench/fixtures/tiny_corpus.txt", "bench/results/tokenizer_bench.py.json", "--vocab-size", "256", "--min-freq", "1", "--seed", "1337"]
    },
    {
      "id": "dataset_inspect_cli",
      "description": "Dataset inspect pass with deterministic batching",
      "enkai_command": ["${ENKAI_BIN}", "dataset-lite", "inspect", "bench/fixtures/tiny_corpus.txt", "bench/results/tokenizer_bench.json", "--seq-len", "8", "--batch-size", "4", "--seed", "1337", "--shuffle", "--output", "bench/results/dataset_bench.json"],
      "python_command": ["${PYTHON_EXE}", "bench/python/dataset_inspect_cli.py", "bench/fixtures/tiny_corpus.txt", "bench/results/tokenizer_bench.py.json", "--seq-len", "8", "--batch-size", "4", "--seed", "1337", "--shuffle", "--output", "bench/results/dataset_bench.py.json"]
    },
    {
      "id": "http_serve_loop",
      "description": "Serve local endpoint and run request loop",
      "enkai_command": ["${PYTHON_EXE}", "bench/python/http_serving_bench.py", "--impl", "enkai", "--enkai-bin", "${ENKAI_BIN}", "--requests", "120"],
      "python_command": ["${PYTHON_EXE}", "bench/python/http_serving_bench.py", "--impl", "python", "--requests", "120"]
    },
    {
      "id": "sqlite_ops",
      "description": "Create, insert, and query SQLite rows",
      "enkai_command": ["${ENKAI_BIN}", "run", "bench/enkai/kernel_db_ops.enk"],
      "python_command": ["${PYTHON_EXE}", "bench/python/kernel_db_ops.py"]
    }
  ]
}
