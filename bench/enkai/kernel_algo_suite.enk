import std::algo

fn main() -> Int ::
    let i := 0
    while i < 20000 ::
        let top := algo.top_k_ints([9, 1, 8, 2, 7, 3, 6, 4, 5], 4)
        let split := algo.split_indices(20, 0.2, 42, 1)
        if top == [] ::
            return 1
        ::
        if split.test_count != 4 ::
            return 1
        ::
        i := i + 1
    ::
    return 0
::

main()
