import json
import std::pool

fn main() ::
    let reusable := pool.make(100)
    let preload := 0
    while preload < 100 ::
        pool.release(reusable, preload)
        preload := preload + 1
    ::

    let idx := 0
    while idx < 10000 ::
        let value := pool.acquire(reusable)?
        pool.release(reusable, value)
        idx := idx + 1
    ::

    let out := json.parse("{}")
    out.available := pool.available(reusable)
    out.capacity := pool.capacity(reusable)
    out.stats := pool.stats(reusable)
    return out
::

main()
