// Minimal frontend sanity specimen for the nn/tensor stack.

fn main() -> Int ::
    let vocab := 32
    let dim := 64
    let batch := 4
    let seq := 8

    let total_tokens := batch * seq
    let model_width := vocab + dim
    let sanity := json.parse("{}")
    sanity.total_tokens := total_tokens
    sanity.model_width := model_width
    return total_tokens
::
