{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    {"open": "(", "close": ")"},
    {"open": "[", "close": "]"},
    {"open": "{", "close": "}"},
    {"open": "\"", "close": "\"", "notIn": ["string", "comment"]},
    {"open": "/*", "close": "*/", "notIn": ["string"]}
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@#$%^&*()=+[{]}\\\\|;:'\\\",.<>/?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^(?!\\s*::(?:fn|if|else|while|for|policy|match|struct|enum|impl|module|class|trait)?\\s*(?://.*)?$).*::\\s*(?://.*)?$",
    "decreaseIndentPattern": "^\\s*::(?:fn|if|else|while|for|policy|match|struct|enum|impl|module|class|trait)?\\s*(?://.*)?$"
  },
  "folding": {
    "markers": {
      "start": "^(?!\\s*::).*::\\s*(?://.*)?$",
      "end": "^\\s*::(?:fn|if|else|while|for|policy|match|struct|enum|impl|module|class|trait)?\\s*(?://.*)?$"
    }
  }
}
