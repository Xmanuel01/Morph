{
  "Main function": {
    "prefix": "fnmain",
    "body": [
      "fn main() ::",
      "    ${0}",
      "::fn"
    ],
    "description": "Main entry function with tagged closer"
  },
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params})${3: -> ${4:Type}} ::",
      "    ${0}",
      "::fn"
    ],
    "description": "Function declaration with tagged closer"
  },
  "Let binding": {
    "prefix": "let",
    "body": "let ${1:name}${2:: ${3:Type}} := ${0}",
    "description": "Immutable let binding"
  },
  "Mutable binding": {
    "prefix": "mut",
    "body": "mut ${1:name}${2:: ${3:Type}} := ${0}",
    "description": "Mutable binding"
  },
  "Constant": {
    "prefix": "const",
    "body": "const ${1:NAME}${2:: ${3:Type}} := ${0}",
    "description": "Compile-time constant binding"
  },
  "If": {
    "prefix": "if",
    "body": [
      "if ${1:condition} ::",
      "    ${0}",
      "::if"
    ],
    "description": "If block with tagged closer"
  },
  "If else": {
    "prefix": "ifelse",
    "body": [
      "if ${1:condition} ::",
      "    ${2}",
      "::if",
      "else ::",
      "    ${0}",
      "::else"
    ],
    "description": "If/else block with tagged closers"
  },
  "While": {
    "prefix": "while",
    "body": [
      "while ${1:condition} ::",
      "    ${0}",
      "::while"
    ],
    "description": "While loop with tagged closer"
  },
  "For": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iterable} ::",
      "    ${0}",
      "::for"
    ],
    "description": "For loop with tagged closer"
  },
  "Match": {
    "prefix": "match",
    "body": [
      "match ${1:value} ::",
      "    ${2:_} => ${0}",
      "::match"
    ],
    "description": "Match expression with tagged closer"
  },
  "Policy default": {
    "prefix": "policy",
    "body": [
      "policy default ::",
      "    allow ${1:io.write}",
      "::policy"
    ],
    "description": "Default policy block"
  },
  "Import std module": {
    "prefix": "import",
    "body": "import std::${1:io}",
    "description": "Import a standard library module"
  },
  "Native import block": {
    "prefix": "nativeimport",
    "body": [
      "native::import \"${1:lib}\" ::",
      "    fn ${2:name}(${3:args}) -> ${4:Type}",
      "::"
    ],
    "description": "Native import block"
  },
  "Print line": {
    "prefix": "line",
    "body": "io.stdout_write_text(${1:text})",
    "description": "Write text to stdout"
  },
  "Tensor import starter": {
    "prefix": "tensorstart",
    "body": [
      "import std::tensor",
      "",
      "fn main() ::",
      "    let dev := tensor.device(\"${1:cpu}\")",
      "    let x := tensor.zeros([${2:2}, ${3:2}], \"${4:fp32}\", dev)",
      "    ${0}",
      "::fn"
    ],
    "description": "Tensor program starter"
  }
}
