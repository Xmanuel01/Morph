{
  "name": "enkai-language",
  "displayName": "Enkai Language Support",
  "description": "Syntax highlighting, snippets, indentation, and folding for the Enkai programming language.",
  "version": "0.2.0",
  "publisher": "xmanuel01",
  "license": "Apache-2.0",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "enkai",
    "ai",
    "language",
    "syntax",
    "highlighting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Xmanuel01/Enkai.git"
  },
  "bugs": {
    "url": "https://github.com/Xmanuel01/Enkai/issues"
  },
  "homepage": "https://github.com/Xmanuel01/Enkai",
  "contributes": {
    "languages": [
      {
        "id": "enkai",
        "aliases": [
          "Enkai",
          "enkai"
        ],
        "extensions": [
          ".enk",
          ".enkai",
          ".en"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "enkai",
        "scopeName": "source.enkai",
        "path": "./syntaxes/enkai.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "enkai",
        "path": "./snippets/enkai.json"
      }
    ]
  }
}
