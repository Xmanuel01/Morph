{
  "name": "Enkai",
  "scopeName": "source.enkai",
  "fileTypes": ["enk", "enkai", "en"],
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#nativeImports"},
    {"include": "#imports"},
    {"include": "#policies"},
    {"include": "#functions"},
    {"include": "#typeDecls"},
    {"include": "#blockClosers"},
    {"include": "#blockOpeners"},
    {"include": "#keywords"},
    {"include": "#types"},
    {"include": "#stdModules"},
    {"include": "#numbers"},
    {"include": "#functionCalls"},
    {"include": "#operators"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.enkai",
          "match": "//.*$"
        },
        {
          "name": "comment.block.enkai",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.enkai",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.enkai",
              "match": "\\\\(\\\\|\"|n|t|r|0|u\\{[0-9A-Fa-f]+\\})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.enkai",
          "match": "\\b(?:0x[0-9A-Fa-f_]+|0b[01_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d+)?)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.enkai",
          "match": "\\b(if|else|for|while|match|try|catch|return|break|continue|spawn|await|async)\\b"
        },
        {
          "name": "keyword.declaration.enkai",
          "match": "\\b(fn|let|mut|const|type|struct|enum|impl|trait|module|class|import|use|pub|native|tool|agent|policy|memory|prompt|model)\\b"
        },
        {
          "name": "keyword.other.enkai",
          "match": "\\b(allow|deny|as|in|with)\\b"
        },
        {
          "name": "keyword.operator.logical.enkai",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "constant.language.enkai",
          "match": "\\b(true|false|none|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.enkai",
          "match": "\\b(Int|Float|Bool|String|Void|Any|Array|Vector|SparseVector|Tensor|Dataset|Model|Device|DType|Optional|Result|Channel|TaskHandle|Request|Response|Buffer|Json|Map|Set)\\b"
        }
      ]
    },
    "stdModules": {
      "patterns": [
        {
          "name": "support.module.enkai",
          "match": "\\b(io|json|sparse|tensor|nn|optim|dataset|tokenizer|checkpoint|net|http|fs|hash|db|tls|sim|event|pool|agent|model)\\b(?=\\.)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.declaration.enkai",
          "match": "\\bfn\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {"name": "entity.name.function.enkai"}
          }
        }
      ]
    },
    "functionCalls": {
      "patterns": [
        {
          "name": "entity.name.function.call.enkai",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "typeDecls": {
      "patterns": [
        {
          "name": "meta.type.declaration.enkai",
          "match": "\\b(type|struct|enum|impl|trait|module|class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {"name": "keyword.declaration.enkai"},
            "2": {"name": "entity.name.type.enkai"}
          }
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.enkai",
          "match": "\\b(import|use)\\s+([A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": {"name": "keyword.control.import.enkai"},
            "2": {"name": "entity.name.namespace.enkai"}
          }
        }
      ]
    },
    "nativeImports": {
      "patterns": [
        {
          "name": "meta.native.import.enkai",
          "match": "\\bnative::import\\s+(\"[^\"]+\")",
          "captures": {
            "1": {"name": "string.quoted.double.enkai"}
          }
        }
      ]
    },
    "policies": {
      "patterns": [
        {
          "name": "meta.policy.declaration.enkai",
          "match": "\\bpolicy\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {"name": "entity.name.namespace.policy.enkai"}
          }
        },
        {
          "name": "meta.policy.permission.enkai",
          "match": "\\b(allow|deny)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": {"name": "keyword.other.enkai"},
            "2": {"name": "entity.name.namespace.permission.enkai"}
          }
        }
      ]
    },
    "blockOpeners": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.enkai",
          "match": "::\\s*$"
        }
      ]
    },
    "blockClosers": {
      "patterns": [
        {
          "name": "punctuation.section.block.end.tagged.enkai",
          "match": "^\\s*::(fn|if|else|while|for|policy|match|struct|enum|impl|module|class|trait)\\b",
          "captures": {
            "1": {"name": "entity.name.tag.block.enkai"}
          }
        },
        {
          "name": "punctuation.section.block.end.enkai",
          "match": "^\\s*::\\s*$"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.enkai",
          "match": ":="
        },
        {
          "name": "keyword.operator.enkai",
          "match": "(->|=>|==|!=|<=|>=|::|\\+|\\-|\\*|/|%|\\?|=|\\.)"
        }
      ]
    }
  }
}
