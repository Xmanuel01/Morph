{
  "schema_version": 1,
  "profile": "full_platform",
  "checks": [
    {
      "id": "fmt",
      "description": "Rust formatting gate",
      "command": [
        "cargo",
        "fmt",
        "--all",
        "--check"
      ]
    },
    {
      "id": "clippy",
      "description": "Workspace lint gate",
      "command": [
        "cargo",
        "clippy",
        "--workspace",
        "--all-targets",
        "--",
        "-D",
        "warnings"
      ]
    },
    {
      "id": "test",
      "description": "Workspace unit/integration tests",
      "command": [
        "cargo",
        "test",
        "--workspace",
        "--",
        "--skip",
        "http_server_handles_concurrent_requests"
      ]
    },
    {
      "id": "docs-consistency",
      "description": "Docs/spec/contract consistency check",
      "command": [
        "${PYTHON}",
        "scripts/check_docs_consistency.py"
      ]
    },
    {
      "id": "frontend-contract",
      "description": "Frontend/backend contract snapshot test",
      "command": [
        "cargo",
        "test",
        "-p",
        "enkai",
        "--bin",
        "enkai",
        "frontend::tests::contract_snapshots_match_reference_files"
      ]
    },
    {
      "id": "backend-http-contract",
      "description": "Backend HTTP contract smoke test",
      "command": [
        "cargo",
        "test",
        "-p",
        "enkairt",
        "--test",
        "http",
        "http_get_roundtrip"
      ]
    },
    {
      "id": "grpc-smoke",
      "description": "Backend gRPC runtime smoke test",
      "command": [
        "${PYTHON}",
        "scripts/readiness_grpc_smoke.py",
        "--enkai-bin",
        "${ENKAI_BIN}",
        "--workspace",
        ".",
        "--output",
        "artifacts/readiness/grpc_smoke.json"
      ]
    },
    {
      "id": "grpc-evidence-verify",
      "description": "Backend gRPC evidence verification",
      "command": [
        "${PYTHON}",
        "scripts/verify_grpc_evidence.py",
        "--summary",
        "artifacts/readiness/grpc_smoke.json",
        "--probe",
        "artifacts/grpc/probe.json",
        "--server-log",
        "artifacts/grpc/server.jsonl",
        "--conversation-state",
        "artifacts/grpc/conversation_state.json",
        "--output",
        "artifacts/readiness/grpc_evidence_verify.json"
      ]
    },
    {
      "id": "llm-runtime-smoke",
