    {
      "id": "benchmark-fairness",
      "description": "Benchmark fairness contract gate",
      "command": [
        "enkai",
        "bench",
        "run",
        "--suite",
        "official_v2_3_0_matrix",
        "--baseline",
        "python",
        "--iterations",
        "1",
        "--warmup",
        "0",
        "--fairness-check-only",
        "--enkai-bin",
        "${ENKAI_BIN}",
        "--output",
        "bench/results/full_platform_fairness.json"
      ]
    },
    {
      "id": "benchmark-target",
      "description": "Benchmark target smoke gate",
      "command": [
        "enkai",
        "bench",
        "run",
        "--suite",
        "official_v2_3_0_matrix",
        "--baseline",
        "python",
        "--iterations",
        "2",
        "--warmup",
        "1",
        "--target-speedup",
        "5",
        "--target-memory",
        "5",
        "--enforce-target",
        "--enkai-bin",
        "${ENKAI_BIN}",
        "--output",
        "bench/results/full_platform_targets_smoke.json"
      ]
    },
