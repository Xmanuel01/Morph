{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EnkaiConversationStateV1",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "source",
    "updated_ms"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "source": {
      "type": "string"
    },
    "updated_ms": {
      "type": "integer"
    },
    "user_text": {
      "type": "string"
    },
    "reply": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
