fn require_world_state(globals, value, message: String) ::
    if value.kind != "SimWorld" ::
        return fail_state(message)
    ::
    let world_id := parse_i64(json.stringify(value.world_id))
    let state := world_state_record(globals, world_id)
    if state == none ::
        return fail_state("sim world handle is not registered")
    ::
    let out := json.parse("{}")
    out.ok := true
    out.value := state?
    out.world_id := world_id
    out.globals := globals
    return out
::

