fn insert_event_sorted(head, time: Float, seq: Int, event) ::
    let entry := push_event_entry(none, time, seq, event)
    if head == none ::
        return entry
    ::
    if event_before(time, seq, head?.time, head?.seq) ::
        entry.next := head
        return entry
    ::
    let node := head
    while node?.next != none ::
        if event_before(time, seq, node?.next?.time, node?.next?.seq) ::
            entry.next := node?.next
            node.next := entry
            return head
        ::
        node := node?.next
    ::
