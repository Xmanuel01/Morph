        ::
        let value_state := require_float_arg(args, 1, "snn.set_decay expects value")
        if not value_state.ok ::
            return value_state
        ::
        snn_state.value.decay := parse_f64(json.stringify(value_state.value))
        let next_globals := store_snn_state_record(snn_state.globals, snn_state.snn_id, snn_state.value)
        return ok_state(null_value(), next_globals)
    ::
    if name == "snn.get_decay" ::
        let net_state := require_kind_arg(args, 0, "SnnNetwork", "snn.get_decay expects SnnNetwork")
        if not net_state.ok ::
            return net_state
        ::
        let snn_state := require_snn_state(globals, net_state.value, "snn.get_decay expects SnnNetwork")
        if not snn_state.ok ::
            return snn_state
        ::
        return ok_state(float_value(parse_f64(json.stringify(snn_state.value.decay))), none)
    ::
    if name == "snn.step" ::
        let net_state := require_kind_arg(args, 0, "SnnNetwork", "snn.step expects SnnNetwork")
        if not net_state.ok ::
            return net_state
        ::
        let snn_state := require_snn_state(globals, net_state.value, "snn.step expects SnnNetwork")
        if not snn_state.ok ::
            return snn_state
        ::
        let dense_state := require_kind_arg(args, 1, "List", "snn.step expects input list")
        if not dense_state.ok ::
            return dense_state
        ::
        let spikes := none
        let new_potentials := none
        let idx := 0
        let neuron_count := parse_i64(json.stringify(snn_state.value.neuron_count))
        while idx < neuron_count ::
            let recurrent := 0.0
            let syn := snn_state.value.synapses.entries
            while syn != none ::
                let syn_to := syn?.col
                let syn_from := syn?.row
                let syn_weight := syn?.value
                if syn_to == idx ::
                    let spike_node := snn_state.value.last_spikes
                    while spike_node != none ::
                        if spike_node?.value.kind == "Int" ::
                            if parse_i64(json.stringify(spike_node?.value.value)) == syn_from ::
                                recurrent := recurrent + parse_f64(json.stringify(syn_weight))
                            ::
                        ::
                        spike_node := spike_node?.next
                    ::
                ::
                syn := syn?.next
            ::
            let current := load_sparse_vector_entry(snn_state.value.potentials, idx)
            let potential := 0.0
            if current != none ::
                potential := current?
            ::
            let threshold := load_sparse_vector_entry(snn_state.value.thresholds, idx)
            let threshold_value := 1.0
            if threshold != none ::
                threshold_value := threshold?
            ::
            let decay := parse_f64(json.stringify(snn_state.value.decay))
            let next_value := potential * decay + load_dense_value(dense_state.value.items, idx) + recurrent
            let fired := next_value >= threshold_value
            let stored_value := next_value
            if fired ::
                stored_value := 0.0
                spikes := append_list_item(spikes, int_value(idx))
            ::
            new_potentials := store_sparse_vector_entry(new_potentials, idx, stored_value)
            idx := idx + 1
        ::
        snn_state.value.potentials := new_potentials
        snn_state.value.last_spikes := spikes
        let next_globals := store_snn_state_record(snn_state.globals, snn_state.snn_id, snn_state.value)
        return ok_state(list_value(spikes), next_globals)
    ::
    if name == "snn.spikes" ::
        let net_state := require_kind_arg(args, 0, "SnnNetwork", "snn.spikes expects SnnNetwork")
        if not net_state.ok ::
            return net_state
        ::
        let snn_state := require_snn_state(globals, net_state.value, "snn.spikes expects SnnNetwork")
        if not snn_state.ok ::
            return snn_state
        ::
        return ok_state(list_value(snn_state.value.last_spikes), none)
    ::
    if name == "snn.potentials" ::
        let net_state := require_kind_arg(args, 0, "SnnNetwork", "snn.potentials expects SnnNetwork")
        if not net_state.ok ::
            return net_state
        ::
        let snn_state := require_snn_state(globals, net_state.value, "snn.potentials expects SnnNetwork")
        if not snn_state.ok ::
            return snn_state
        ::
        let out := none
        let idx := 0
        let neuron_count := parse_i64(json.stringify(snn_state.value.neuron_count))
        while idx < neuron_count ::
            let value := load_sparse_vector_entry(snn_state.value.potentials, idx)
            if value == none ::
                out := append_list_item(out, float_value(0.0))
            ::
            else ::
                out := append_list_item(out, float_value(value?))
            ::
            idx := idx + 1
        ::
        return ok_state(list_value(out), none)
    ::
    if name == "snn.synapses" ::
        let net_state := require_kind_arg(args, 0, "SnnNetwork", "snn.synapses expects SnnNetwork")
        if not net_state.ok ::
            return net_state
        ::
        let snn_state := require_snn_state(globals, net_state.value, "snn.synapses expects SnnNetwork")
        if not snn_state.ok ::
            return snn_state
        ::
        return ok_state(snn_state.value.synapses, none)
    ::
    return fail_state("unsupported snn builtin")
::

fn runtime_builtin_agent(globals, args, name: String) ::
    if name == "agent.make" ::
        let world_state := require_kind_arg(args, 0, "SimWorld", "agent.make expects SimWorld")
        if not world_state.ok ::
            return world_state
        ::
        let spatial_state := require_kind_arg(args, 1, "SpatialIndex", "agent.make expects SpatialIndex")
        if not spatial_state.ok ::
            return spatial_state
        ::
        let world_handle_state := require_world_state(globals, world_state.value, "agent.make expects SimWorld")
        if not world_handle_state.ok ::
            return world_handle_state
        ::
        let spatial_handle_state := require_spatial_state(globals, spatial_state.value, "agent.make expects SpatialIndex")
        if not spatial_handle_state.ok ::
            return spatial_handle_state
        ::
        return allocate_agent_env(globals, world_handle_state.world_id, spatial_handle_state.spatial_id)
    ::
    if name == "agent.register" ::
        let env_state := require_kind_arg(args, 0, "AgentEnv", "agent.register expects AgentEnv")
        if not env_state.ok ::
            return env_state
        ::
        let env_handle_state := require_agent_env_state(globals, env_state.value, "agent.register expects AgentEnv")
        if not env_handle_state.ok ::
            return env_handle_state
