    ::
    if name == "sparse.set" ::
        return true
    ::
    if name == "sparse.get" ::
        return true
    ::
    if name == "sparse.dot" ::
        return true
    ::
    if name == "sparse.matvec" ::
        return true
    ::
    if name == "sparse.nonzero" ::
        return true
    ::
    if name == "sparse.nonzero_vector" ::
        return true
    ::
