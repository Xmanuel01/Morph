fn build_record_from_stack(stack, field_count: Int) ::
    let fields := none
    let remaining := stack
    let field_idx := 0
    while field_idx < field_count ::
        let value_pop := pop_stack(remaining)
        if not value_pop.ok ::
            return fail_state(value_pop.error)
        ::
        let key_pop := pop_stack(value_pop.next)
        if not key_pop.ok ::
            return fail_state(key_pop.error)
        ::
        if key_pop.value.kind != "String" ::
            return fail_state("MakeRecord requires string keys")
        ::
        fields := store_named_field(fields, key_pop.value.value, value_pop.value)
        remaining := key_pop.next
        field_idx := field_idx + 1
    ::
    return ok_state(record_value(fields), remaining)
::

fn build_list_from_stack(stack, item_count: Int) ::
    let items := none
    let remaining := stack
    let item_idx := 0
    while item_idx < item_count ::
        let popped := pop_stack(remaining)
        if not popped.ok ::
            return fail_state(popped.error)
        ::
        items := push_list_item(items, popped.value)
        remaining := popped.next
        item_idx := item_idx + 1
    ::
    return ok_state(list_value(items), remaining)
::

fn list_set_item(head, index: Int, value) ::
    let out := json.parse("{}")
    out.ok := false
    out.error := "list index out of bounds"
    out.items := head
    if index < 0 ::
        return out
    ::
    let node := head
    let current := 0
    while node != none ::
        if current == index ::
            node.value := value
            out.ok := true
            out.error := none
            out.items := head
            return out
        ::
        current := current + 1
        node := node?.next
    ::
    return out
::

fn build_closure_from_stack(program, stack, function_index: Int, capture_count: Int) ::
    if function_index < 0 ::
        return fail_state("closure function index must be non-negative")
    ::
    if function_index >= program.functions_count ::
        return fail_state("closure function index out of range")
    ::
    let built := build_list_from_stack(stack, capture_count)
    if not built.ok ::
        return built
    ::
    let function := program.functions[function_index]
    let function_arity := parse_i64(json.stringify(function.arity))
    if function_arity < capture_count ::
        return fail_state("closure capture arity mismatch")
    ::
    let closure := closure_value(function_index, function_arity - capture_count, built.value.items)
    return ok_state(closure, built.globals)
::

