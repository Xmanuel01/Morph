fn push_event_entry(head, time: Float, seq: Int, event) ::
    let entry := json.parse("{}")
    entry.time := time
    entry.seq := seq
    entry.event := event
    entry.next := head
    return entry
::

fn event_before(left_time: Float, left_seq: Int, right_time: Float, right_seq: Int) -> Bool ::
    if left_time < right_time ::
        return true
    ::
    if left_time > right_time ::
        return false
    ::
    return left_seq < right_seq
::

fn extract_min_event(head) ::
    if head == none ::
        return ok_state(none, none)
    ::
    let min_time := head?.time
    let min_seq := head?.seq
    let min_event := head?.event
    let node := head?.next
    while node != none ::
        if event_before(node?.time, node?.seq, min_time, min_seq) ::
            min_time := node?.time
            min_seq := node?.seq
            min_event := node?.event
        ::
        node := node?.next
    ::
    let remaining := none
    node := head
    let removed := false
    while node != none ::
        let skip := false
        if not removed ::
            if node?.seq == min_seq ::
                if node?.time == min_time ::
                    skip := true
                    removed := true
                ::
            ::
        ::
        if not skip ::
            remaining := push_event_entry(remaining, node?.time, node?.seq, node?.event)
        ::
        node := node?.next
    ::
    let result := json.parse("{}")
    result.time := min_time
    result.seq := min_seq
    result.event := min_event
    return ok_state(result, remaining)
::

