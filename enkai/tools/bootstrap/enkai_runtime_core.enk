fn callable_initial_locals(callable) ::
    let out := json.parse("{}")
    out.ok := true
    out.function_index := -1
    out.locals := none
    if callable.kind == "Function" ::
        out.function_index := parse_i64(json.stringify(callable.function_index))
        return out
    ::
    if callable.kind == "Closure" ::
        out.function_index := parse_i64(json.stringify(callable.function_index))
        let locals := none
        let slot := 0
        let capture_node := callable.captures
        while capture_node != none ::
            locals := store_local(locals, slot, capture_node?.value)
            slot := slot + 1
            capture_node := capture_node?.next
        ::
        out.locals := locals
        return out
    ::
    out.ok := false
    out.error := "task.spawn expects Function or Closure"
    return out
::

fn push_sparse_vector_entry(head, index: Int, value: Float) ::
