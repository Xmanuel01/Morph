fn remove_entity_entry(head, id: Int) ::
    let remaining := none
    let removed := false
    let node := head
    while node != none ::
        let skip := false
        if not removed ::
            if node?.id == id ::
                skip := true
                removed := true
            ::
        ::
        if not skip ::
            remaining := push_entity_entry(remaining, node?.id, node?.value)
        ::
        node := node?.next
    ::
    let out := json.parse("{}")
    out.removed := removed
    out.items := remaining
    return out
::

