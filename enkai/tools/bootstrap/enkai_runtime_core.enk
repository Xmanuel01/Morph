    let node := items
    while node != none ::
        entity_ids := append_list_item(entity_ids, int_value(node?.id))
        node := node?.next
    ::
    let sorted := none
    let expected := 0
    while expected < list_length(entity_ids) ::
        let min_id := none
        let min_value := none
        let cursor := items
        while cursor != none ::
            if min_id == none ::
                min_id := cursor?.id
                min_value := cursor?.value
            ::
            else ::
                if cursor?.id < min_id? ::
                    min_id := cursor?.id
                    min_value := cursor?.value
