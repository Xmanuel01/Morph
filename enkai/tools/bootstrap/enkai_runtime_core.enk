fn is_truthy(value) -> Bool ::
    if value.kind == "Bool" ::
        if value.value == true ::
            return true
        ::
        return false
    ::
    if value.kind == "Null" ::
        return false
    ::
    if value.kind == "Int" ::
        let value_int := parse_i64(json.stringify(value.value))
        return value_int != 0
    ::
    if value.kind == "Float" ::
        let value_float := parse_f64(json.stringify(value.value))
        return value_float != 0.0
    ::
    return true
::

fn jump_if_false_keeps_value(function, ip: Int, target: Int) -> Bool ::
    let next_ip := ip + 1
    if next_ip < function.code_count ::
        if function.code[next_ip].kind == "Pop" ::
            return true
        ::
    ::
    if target > -1 ::
        if target < function.code_count ::
            if function.code[target].kind == "Pop" ::
                return true
            ::
        ::
    ::
    return false
::

fn is_supported_instruction_kind(kind: String) -> Bool ::
    if kind == "Const" ::
        return true
    ::
    if kind == "MakeClosure" ::
        return true
    ::
    if kind == "MakeRecord" ::
        return true
    ::
    if kind == "MakeList" ::
        return true
    ::
