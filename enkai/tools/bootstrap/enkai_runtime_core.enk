fn append_traversal_steps_for_length(length: Int) -> Int ::
    let steps := 0
    let next := 0
    while next < length ::
        steps := steps + next
        next := next + 1
    ::
    return steps
::

fn metric_record_append(globals, length: Int, label: String) ::
    let next_globals := metric_inc(globals, metric_list_append_calls_slot(), 1)
    next_globals := metric_inc(next_globals, metric_list_append_steps_slot(), length)
    let total_steps := metric_value(next_globals, metric_list_append_steps_slot())
    if total_steps > runtime_traversal_step_limit() ::
        let detail := json.parse("{}")
        detail.error := "runtime append traversal step limit exceeded"
        detail.label := label
        detail.append_length := length
        detail.total_append_steps := total_steps
        detail.limit := runtime_traversal_step_limit()
        return fail_state_with_globals(json.stringify(detail), next_globals)
    ::
    return ok_state(null_value(), next_globals)
::

fn list_get(items, index: Int) ::
    if index < 0 ::
        return none
    ::
    let current := 0
    let node := items
    while node != none ::
        if current == index ::
            return node?.value
        ::
        current := current + 1
        node := node?.next
    ::
    return none
::

