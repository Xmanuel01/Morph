fn lookup_function_index_by_name(program, name: String) ::
    let function_index := 0
    let tail_name := qualified_name_tail(name)
    let tail_match := none
    let tail_match_count := 0
    while function_index < program.functions_count ::
        let function := program.functions[function_index]
        if function != none ::
            if function?.name == name ::
                return int_value(function_index)
            ::
            if function?.name == tail_name ::
                if tail_match == none ::
                    tail_match := int_value(function_index)
                ::
                tail_match_count := tail_match_count + 1
            ::
        ::
        function_index := function_index + 1
    ::
    if tail_match_count == 1 ::
        return tail_match
    ::
    return none
::

fn runtime_entry_index(program) -> Int ::
    let declared_main := lookup_function_index_by_name(program, "main")
    if declared_main != none ::
        return parse_i64(json.stringify(declared_main?.value))
    ::
    return parse_i64(json.stringify(program.main_index))
::

fn should_skip_prelude_main_call(program, callee_index: Int, argc: Int) -> Bool ::
    if argc != 0 ::
        return false
    ::
    let declared_main := lookup_function_index_by_name(program, "main")
    if declared_main == none ::
        return false
    ::
    return callee_index == parse_i64(json.stringify(declared_main?.value))
::

fn install_globals(program) ::
    let globals := none
    let global_slot := 0
    while global_slot < program.globals_count ::
        globals := store_global(globals, global_slot, null_value())
        global_slot := global_slot + 1
    ::
    let global_index := 0
    while global_index < program.global_inits_count ::
        let init_value := program.global_inits[global_index]
        if init_value != none ::
            if init_value?.kind != "Null" ::
                let constant_state := materialize_constant(init_value?)
                if not constant_state.ok ::
                    return constant_state
                ::
                globals := store_global(globals, global_index, constant_state.value)
            ::
        ::
        global_index := global_index + 1
    ::
    global_index := 0
    while global_index < program.globals_count ::
        let global_name := program.globals[global_index]
        let current_value := load_global(globals, global_index)
        if current_value != none ::
            if current_value?.kind == "Null" ::
                let function_index := lookup_function_index_by_name(program, global_name)
                if function_index != none ::
                    globals := store_global(globals, global_index, function_value(function_index.value))
                ::
                let updated_value := load_global(globals, global_index)
                if updated_value != none ::
                    if updated_value?.kind == "Null" ::
                        globals := install_builtin_global(globals, global_index, global_name)
                    ::
                ::
            ::
        ::
        global_index := global_index + 1
    ::
    return ok_state(null_value(), globals)
::

fn runtime_value_to_json_value(globals, value, depth: Int) ::
    globals := metric_inc(globals, metric_json_nodes_slot(), 1)
    globals := metric_max(globals, metric_json_max_depth_slot(), depth)
    if depth > runtime_json_depth_limit() ::
        let detail := json.parse("{}")
        detail.error := "runtime result JSON conversion depth limit exceeded"
        detail.depth := depth
        detail.limit := runtime_json_depth_limit()
        return fail_state_with_globals(json.stringify(detail), globals)
    ::
    if metric_value(globals, metric_json_nodes_slot()) > runtime_json_node_limit() ::
        let detail := json.parse("{}")
        detail.error := "runtime result JSON conversion node limit exceeded"
        detail.nodes := metric_value(globals, metric_json_nodes_slot())
        detail.limit := runtime_json_node_limit()
        return fail_state_with_globals(json.stringify(detail), globals)
    ::
    if value.kind == "Int" ::
        return ok_state(int_value(parse_i64(json.stringify(value.value))), globals)
    ::
    if value.kind == "Float" ::
        return ok_state(float_value(parse_f64(json.stringify(value.value))), globals)
    ::
    if value.kind == "Bool" ::
        return ok_state(bool_value(value.value), globals)
    ::
    if value.kind == "String" ::
        return ok_state(string_value(value.value), globals)
    ::
    if value.kind == "Null" ::
        return ok_state(null_value(), globals)
    ::
    if value.kind == "List" ::
        let out := json.parse("{}")
        out.kind := "List"
        let node := value.items
        let encoded_items_reversed := none
        while node != none ::
            let item_state := runtime_value_to_json_value(globals, node?.value, depth + 1)
            if not item_state.ok ::
                return item_state
            ::
            globals := item_state.globals
            encoded_items_reversed := push_list_item(encoded_items_reversed, item_state.value)
            node := node?.next
        ::
        out.items := reverse_list_items(encoded_items_reversed)
        return ok_state(out, globals)
    ::
    if value.kind == "Record" ::
        let out := json.parse("{}")
        out.kind := "Record"
        let node := value.fields
        let encoded_fields := none
        while node != none ::
            let item_state := runtime_value_to_json_value(globals, node?.value, depth + 1)
            if not item_state.ok ::
                return item_state
            ::
            globals := item_state.globals
            encoded_fields := store_named_field(encoded_fields, node?.name, item_state.value)
            node := node?.next
        ::
        out.fields := encoded_fields
        return ok_state(out, globals)
    ::
    if value.kind == "EventLogChunks" ::
        let out := json.parse("{}")
        out.kind := "EventLogChunks"
        out.count := parse_i64(json.stringify(value.count))
        let encoded_chunks_reversed := none
        let chunk_node := value.chunks
        while chunk_node != none ::
            let chunk_out := json.parse("{}")
            chunk_out.count := parse_i64(json.stringify(chunk_node?.count))
            let encoded_events_reversed := none
            let event_node := chunk_node?.events
            while event_node != none ::
                let event_value := event_record_value(event_node)
                let event_state := runtime_value_to_json_value(globals, event_value, depth + 1)
                if not event_state.ok ::
                    return event_state
                ::
                globals := event_state.globals
                encoded_events_reversed := push_list_item(encoded_events_reversed, event_state.value)
                event_node := event_node?.next
            ::
            chunk_out.events := encoded_events_reversed
            encoded_chunks_reversed := push_list_item(encoded_chunks_reversed, chunk_out)
            chunk_node := chunk_node?.next
        ::
        out.chunks := encoded_chunks_reversed
        return ok_state(out, globals)
    ::
    return fail_state_with_globals("runtime result kind is outside audited subset", globals)
::

fn summarize_result(globals, value) ::
    let out := json.parse("{}")
    if value.kind == "Int" ::
        out.ok := true
        out.result_kind := "Int"
        out.result := value.value
        out.globals := globals
        return out
    ::
    if value.kind == "Bool" ::
        out.ok := true
        out.result_kind := "Bool"
        out.result := value.value
        out.globals := globals
        return out
    ::
    if value.kind == "Float" ::
        out.ok := true
        out.result_kind := "Float"
        out.result := value.value
        out.globals := globals
        return out
    ::
    if value.kind == "Null" ::
        out.ok := true
        out.result_kind := "Null"
        out.result := none
        out.globals := globals
        return out
    ::
    if value.kind == "String" ::
        out.ok := true
        out.result_kind := "String"
        out.result := value.value
        out.globals := globals
        return out
    ::
    if value.kind == "Record" ::
        let json_state := runtime_value_to_json_value(globals, value, 0)
        if not json_state.ok ::
            return json_state
        ::
        out.ok := true
        out.result_kind := "Record"
        out.result := json_state.value
        out.globals := json_state.globals
        return out
    ::
    if value.kind == "List" ::
        let json_state := runtime_value_to_json_value(globals, value, 0)
        if not json_state.ok ::
            return json_state
        ::
        out.ok := true
        out.result_kind := "List"
        out.result := json_state.value
        out.globals := json_state.globals
        return out
    ::
    out.ok := false
    out.error := "runtime result kind is outside audited subset"
    out.globals := globals
    return out
::

fn prepare_coroutine_worker(program, coro_arg, coro_value) ::
    let prepared := json.parse("{}")
    prepared.has_worker := false
    prepared.function_index := -1
    prepared.locals := none
    let worker := coro_value.worker
    if worker == none ::
        return ok_state(prepared, none)
    ::

    let worker_locals := none
    let worker_function_index := -1
    let visible_arity := 0
    if worker?.kind == "Function" ::
        worker_function_index := worker?.function_index
        let worker_function := program.functions[worker_function_index]
        visible_arity := parse_i64(json.stringify(worker_function.arity))
    ::
    else ::
        if worker?.kind == "Closure" ::
            worker_function_index := worker?.function_index
            visible_arity := parse_i64(json.stringify(worker?.arity))
            let capture_slot := 0
            let capture_node := worker?.captures
            while capture_node != none ::
                worker_locals := store_local(worker_locals, capture_slot, capture_node?.value)
                capture_slot := capture_slot + 1
                capture_node := capture_node?.next
            ::
        ::
        else ::
            return fail_state("sim coroutine worker must be Function or Closure")
        ::
    ::

    let next_slot := 0
    if worker?.kind == "Closure" ::
        let capture_node := worker?.captures
        while capture_node != none ::
            next_slot := next_slot + 1
            capture_node := capture_node?.next
        ::
    ::
    worker_locals := store_local(worker_locals, next_slot, coro_arg)
    let arg_slot := next_slot + 1
    let arg_values := none
    if coro_value.args != none ::
        let arg_node := coro_value.args
        while arg_node != none ::
            arg_values := append_list_item(arg_values, arg_node?.value)
            arg_node := arg_node?.next
        ::
    ::
    else ::
        if coro_value.state != none ::
            arg_values := append_list_item(arg_values, coro_value.state)
        ::
    ::
    if 1 + list_length(arg_values) != visible_arity ::
        return fail_state("sim coroutine arity must match worker arity")
    ::
    let arg_node := arg_values
    while arg_node != none ::
        worker_locals := store_local(worker_locals, arg_slot, arg_node?.value)
        arg_slot := arg_slot + 1
        arg_node := arg_node?.next
    ::

    prepared.has_worker := true
    prepared.function_index := worker_function_index
    prepared.locals := worker_locals
    return ok_state(prepared, none)
::

fn continuation_frame(function_index: Int, locals, stack, ip: Int) ::
    let frame := json.parse("{}")
    frame.function_index := function_index
    frame.locals := locals
    frame.stack := stack
    frame.ip := ip
    return frame
::

fn coroutine_handles_creation_order(globals) ::
    let table := load_global(globals, coroutine_table_slot())
    let handles := none
    let node := table
    while node != none ::
        handles := push_list_item(handles, sim_coroutine_handle(node?.id))
        node := node?.next
    ::
    return handles
::

fn execute_function_resume(program, globals, function_index: Int, locals, active_coro, call_depth: Int, start_ip: Int, start_stack, skip_top_main_call: Bool) ::
    let function := program.functions[function_index]
    let ip := start_ip
    let stack := start_stack
    globals := metric_inc(globals, metric_exec_calls_slot(), 1)
    globals := metric_max(globals, metric_exec_max_depth_slot(), call_depth)
    if metric_value(globals, metric_exec_calls_slot()) > runtime_exec_call_limit() ::
        let detail := json.parse("{}")
        detail.error := "runtime execute_function call limit exceeded"
        detail.function_index := function_index
        detail.calls := metric_value(globals, metric_exec_calls_slot())
        detail.limit := runtime_exec_call_limit()
        return fail_state_with_globals(json.stringify(detail), globals)
    ::
    if call_depth > runtime_exec_depth_limit() ::
        let detail := json.parse("{}")
        detail.error := "runtime execute_function depth limit exceeded"
        detail.function_index := function_index
        detail.call_depth := call_depth
        detail.limit := runtime_exec_depth_limit()
        return fail_state_with_globals(json.stringify(detail), globals)
    ::

    let instruction_steps := 0
    let instruction_limit := runtime_instruction_limit()
    while ip < function.code_count ::
        instruction_steps := instruction_steps + 1
        if instruction_steps > instruction_limit ::
            let detail := json.parse("{}")
            detail.error := "runtime instruction step limit exceeded"
            detail.function_index := function_index
            detail.function_name := function.name
            detail.ip := ip
            detail.instruction_kind := function.code[ip].kind
            detail.steps := instruction_steps
            detail.limit := instruction_limit
            return fail_state_with_globals(json.stringify(detail), globals)
        ::
        let instruction := function.code[ip]

