fn runtime_builtin_channel(globals, args, name: String) ::
    if name == "chan.make" ::
        return allocate_channel(globals)
    ::
    if name == "chan.send" ::
        let channel := list_get(args, 0)
        let value := list_get(args, 1)
        if channel == none ::
            return fail_state("chan.send expects Channel")
        ::
        if value == none ::
            return fail_state("chan.send expects value")
        ::
        let channel_state := require_channel_state(globals, channel?, "chan.send expects Channel")
        if not channel_state.ok ::
            return channel_state
        ::
        let append_metric := metric_record_append(channel_state.globals, list_length(channel_state.value.queue), "chan.send")
        channel_state.value.queue := append_list_item(channel_state.value.queue, value?)
        let next_globals := store_channel_state_record(append_metric.globals, channel_state.channel_id, channel_state.value)
        let metric_globals := metric_inc(next_globals, metric_channel_sends_slot(), 1)
        return ok_state(null_value(), metric_globals)
    ::
    if name == "chan.recv" ::
        let channel := list_get(args, 0)
        if channel == none ::
            return fail_state("chan.recv expects Channel")
        ::
        let channel_state := require_channel_state(globals, channel?, "chan.recv expects Channel")
        if not channel_state.ok ::
            return channel_state
        ::
        if channel_state.value.queue == none ::
            return fail_state("chan.recv would block: no ready sender in self-host runtime")
        ::
        let message := channel_state.value.queue?.value
        channel_state.value.queue := channel_state.value.queue?.next
        let next_globals := store_channel_state_record(channel_state.globals, channel_state.channel_id, channel_state.value)
        let metric_globals := metric_inc(next_globals, metric_channel_recvs_slot(), 1)
        return ok_state(message, metric_globals)
    ::
    return fail_state("unsupported channel builtin")
::

fn invoke_runtime_builtin(program, globals, active_coro, callee_name: String, args) ::
    if callee_name == "policy.register" ::
        return ok_state(null_value(), none)
    ::
    if callee_name == "json.parse" ::
        let text := list_get(args, 0)
        if text == none ::
            return fail_state("json.parse expects one argument")
        ::
        if text?.kind != "String" ::
            return fail_state("json.parse expects a String argument")
        ::
        let source := text?.value
        return runtime_builtin_json_parse(source)
    ::
    if callee_name == "json.stringify" ::
        return runtime_builtin_json_stringify(args)
    ::
    if is_sparse_builtin_name(callee_name) ::
        return runtime_builtin_sparse(args, callee_name)
    ::
    if is_event_builtin_name(callee_name) ::
        return runtime_builtin_event(globals, args, callee_name)
    ::
    if is_pool_builtin_name(callee_name) ::
        return runtime_builtin_pool(args, callee_name)
    ::
    if is_sim_builtin_name(callee_name) ::
        return runtime_builtin_sim(program, globals, args, callee_name, active_coro)
    ::
    if is_spatial_builtin_name(callee_name) ::
        return runtime_builtin_spatial(globals, args, callee_name)
    ::
    if is_snn_builtin_name(callee_name) ::
        return runtime_builtin_snn(globals, args, callee_name)
    ::
    if is_agent_builtin_name(callee_name) ::
        return runtime_builtin_agent(globals, args, callee_name)
    ::
    if is_channel_builtin_name(callee_name) ::
        return runtime_builtin_channel(globals, args, callee_name)
    ::
    if callee_name == "task.sleep" ::
        let next_globals := metric_inc(globals, metric_task_sleeps_slot(), 1)
        return ok_state(null_value(), next_globals)
    ::
    if callee_name == "print" ::
        return ok_state(null_value(), none)
    ::
    let detail := json.parse("{}")
    detail.error := "unsupported runtime builtin"
    detail.name := callee_name
    return fail_state(json.stringify(detail))
::

fn invoke_native_function(program, globals, callee, call_locals, argc: Int, active_coro) ::
    let args_state := build_call_arg_list(call_locals, argc)
    if not args_state.ok ::
        return args_state
    ::
    let args := args_state.value
    if callee.library == "__runtime_builtin__" ::
        let runtime_state := invoke_runtime_builtin(program, globals, active_coro, callee.name, args)
        if not runtime_state.ok ::
            return runtime_state
        ::
        if runtime_state.globals == none ::
            return ok_state(runtime_state.value, globals)
        ::
        return runtime_state
    ::
    let payload := json.parse("{}")
    payload.library := callee.library
    payload.name := callee.name
    payload.signature := callee.signature
    payload.args := args
    let response_text := runtime_ffi_invoke(json.stringify(payload))
    let response := json.parse(response_text)
    if not response.ok ::
        return fail_state(response.error)
    ::
    return ok_state(response.value, globals)
::

