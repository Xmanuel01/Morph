fn load_named_field(head, name: String) ::
    let node := head
    while node != none ::
        if node?.name == name ::
            return node?.value
        ::
        node := node?.next
    ::
    return none
::

fn store_named_field(head, name: String, value) ::
    let node := head
    while node != none ::
        if node?.name == name ::
            node.value := value
            return head
        ::
        node := node?.next
    ::
    let entry := json.parse("{}")
    entry.name := name
    entry.value := value
    entry.next := head
    return entry
::

fn list_length(items) -> Int ::
    let count := 0
    let node := items
    while node != none ::
        count := count + 1
        node := node?.next
    ::
    return count
::

fn linked_node_length(items) -> Int ::
