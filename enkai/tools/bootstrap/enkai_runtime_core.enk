fn eq_values(lhs, rhs) ::
    if lhs.kind == "Int" ::
        if rhs.kind == "Int" ::
            let lhs_value := parse_i64(json.stringify(lhs.value))
            let rhs_value := parse_i64(json.stringify(rhs.value))
            return ok_state(bool_value(lhs_value == rhs_value), none)
        ::
        if rhs.kind == "Float" ::
            let lhs_value := parse_f64(json.stringify(lhs.value))
            let rhs_value := parse_f64(json.stringify(rhs.value))
            return ok_state(bool_value(lhs_value == rhs_value), none)
        ::
        return ok_state(bool_value(false), none)
    ::

    if lhs.kind == "Float" ::
        if rhs.kind == "Int" ::
            let lhs_value := parse_f64(json.stringify(lhs.value))
            let rhs_value := parse_f64(json.stringify(rhs.value))
            return ok_state(bool_value(lhs_value == rhs_value), none)
        ::
        if rhs.kind == "Float" ::
            let lhs_value := parse_f64(json.stringify(lhs.value))
            let rhs_value := parse_f64(json.stringify(rhs.value))
            return ok_state(bool_value(lhs_value == rhs_value), none)
        ::
        return ok_state(bool_value(false), none)
    ::

    if lhs.kind == "Bool" ::
        if rhs.kind == "Bool" ::
            return ok_state(bool_value(lhs.value == rhs.value), none)
        ::
        return ok_state(bool_value(false), none)
    ::

    if lhs.kind == "String" ::
        if rhs.kind == "String" ::
            return ok_state(bool_value(lhs.value == rhs.value), none)
        ::
        return ok_state(bool_value(false), none)
    ::

    if lhs.kind == "List" ::
        if rhs.kind != "List" ::
            return ok_state(bool_value(false), none)
        ::
        let lhs_node := lhs.items
        let rhs_node := rhs.items
        while lhs_node != none ::
            if rhs_node == none ::
                return ok_state(bool_value(false), none)
            ::
            let item_eq := eq_values(lhs_node?.value, rhs_node?.value)
            if not item_eq.ok ::
                return item_eq
            ::
            if not item_eq.value.value ::
                return ok_state(bool_value(false), none)
            ::
            lhs_node := lhs_node?.next
            rhs_node := rhs_node?.next
        ::
        if rhs_node != none ::
            return ok_state(bool_value(false), none)
        ::
        return ok_state(bool_value(true), none)
    ::

    if lhs.kind == "Record" ::
        if rhs.kind != "Record" ::
            return ok_state(bool_value(false), none)
        ::
        let lhs_field := lhs.fields
        let lhs_count := 0
        let rhs_count := 0
        while lhs_field != none ::
            let rhs_value := load_named_field(rhs.fields, lhs_field?.name)
            if rhs_value == none ::
                return ok_state(bool_value(false), none)
            ::
            let field_eq := eq_values(lhs_field?.value, rhs_value?)
            if not field_eq.ok ::
                return field_eq
            ::
            if not field_eq.value.value ::
                return ok_state(bool_value(false), none)
            ::
            lhs_count := lhs_count + 1
            lhs_field := lhs_field?.next
        ::
        let rhs_field := rhs.fields
        while rhs_field != none ::
            rhs_count := rhs_count + 1
            rhs_field := rhs_field?.next
        ::
        return ok_state(bool_value(lhs_count == rhs_count), none)
    ::

    if lhs.kind == "Null" ::
        return ok_state(bool_value(rhs.kind == "Null"), none)
    ::

    if lhs.kind == "Function" ::
        if rhs.kind == "Function" ::
            return ok_state(bool_value(lhs.function_index == rhs.function_index), none)
        ::
        return ok_state(bool_value(false), none)
    ::

    if lhs.kind == "Closure" ::
        if rhs.kind == "Closure" ::
            let same_function := lhs.function_index == rhs.function_index
            let same_arity := lhs.arity == rhs.arity
            let same_captures := json.stringify(lhs.captures) == json.stringify(rhs.captures)
            return ok_state(bool_value(same_function and same_arity and same_captures), none)
        ::
        return ok_state(bool_value(false), none)
    ::

    if lhs.kind == "NativeFunction" ::
        if rhs.kind == "NativeFunction" ::
            let same_library := lhs.library == rhs.library
            let same_name := lhs.name == rhs.name
            return ok_state(bool_value(same_library and same_name), none)
        ::
        return ok_state(bool_value(false), none)
    ::

    if lhs.kind == "SimWorld" ::
        if rhs.kind == "SimWorld" ::
            return ok_state(bool_value(lhs.world_id == rhs.world_id), none)
        ::
        return ok_state(bool_value(false), none)
    ::

    if lhs.kind == "SimCoroutine" ::
        if rhs.kind == "SimCoroutine" ::
            return ok_state(bool_value(lhs.coro_id == rhs.coro_id), none)
        ::
        return ok_state(bool_value(false), none)
    ::

    let detail := json.parse("{}")
    detail.error := "Eq unsupported kinds"
    detail.lhs_kind := lhs.kind
    detail.rhs_kind := rhs.kind
    return fail_state(json.stringify(detail))
::

fn not_value(value) ::
    if value.kind == "Bool" ::
        return ok_state(bool_value(not value.value), none)
    ::
    if value.kind == "Null" ::
        return ok_state(bool_value(true), none)
    ::
    if value.kind == "Int" ::
        let value_int := parse_i64(json.stringify(value.value))
        return ok_state(bool_value(value_int == 0), none)
    ::
    if value.kind == "Float" ::
        let value_float := parse_f64(json.stringify(value.value))
        return ok_state(bool_value(value_float == 0.0), none)
    ::
    if value.kind == "Function" ::
        return ok_state(bool_value(false), none)
    ::
    return fail_state("Not currently supports Int, Float, Bool, Null, and Function values")
::

fn neg_value(value) ::
    if value.kind == "Int" ::
        let value_int := parse_i64(json.stringify(value.value))
        return ok_state(int_value(0 - value_int), none)
    ::
    if value.kind == "Float" ::
        let value_float := parse_f64(json.stringify(value.value))
        return ok_state(float_value(0.0 - value_float), none)
    ::
    return fail_state("Neg currently supports only Int and Float values")
::

fn neq_values(lhs, rhs) ::
    let eq_state := eq_values(lhs, rhs)
    if not eq_state.ok ::
        return eq_state
    ::
    let neq_state := not_value(eq_state.value)
    if not neq_state.ok ::
        return neq_state
    ::
    return ok_state(neq_state.value, none)
::

