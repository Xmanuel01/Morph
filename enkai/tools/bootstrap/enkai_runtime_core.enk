    ::
    if constant.kind == "Function" ::
        return ok_state(function_value(parse_i64(json.stringify(constant.function_index))), none)
    ::
    if constant.kind == "NativeFunction" ::
        return ok_state(native_function_value(constant.library, constant.name, constant.signature), none)
    ::
    return fail_state("unsupported constant kind")
