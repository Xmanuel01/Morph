            stack := push_stack(lhs_pop.next, mulled.value)
            ip := ip + 1
        ::

        if instruction.kind == "Div" ::
            let rhs_pop := pop_stack(stack)
            if not rhs_pop.ok ::
                return fail_state(rhs_pop.error)
            ::
            let lhs_pop := pop_stack(rhs_pop.next)
            if not lhs_pop.ok ::
                return fail_state(lhs_pop.error)
            ::
            let divided := div_values(lhs_pop.value, rhs_pop.value)
            if not divided.ok ::
                return divided
            ::
            stack := push_stack(lhs_pop.next, divided.value)
            ip := ip + 1
        ::

        if instruction.kind == "Mod" ::
            let rhs_pop := pop_stack(stack)
            if not rhs_pop.ok ::
                return fail_state(rhs_pop.error)
            ::
            let lhs_pop := pop_stack(rhs_pop.next)
            if not lhs_pop.ok ::
                return fail_state(lhs_pop.error)
            ::
            let moduled := mod_values(lhs_pop.value, rhs_pop.value)
            if not moduled.ok ::
                return moduled
            ::
            stack := push_stack(lhs_pop.next, moduled.value)
            ip := ip + 1
        ::

        if instruction.kind == "Eq" ::
            let rhs_pop := pop_stack(stack)
            if not rhs_pop.ok ::
                return fail_state(rhs_pop.error)
            ::
            let lhs_pop := pop_stack(rhs_pop.next)
            if not lhs_pop.ok ::
                return fail_state(lhs_pop.error)
            ::
            let compared := eq_values(lhs_pop.value, rhs_pop.value)
            if not compared.ok ::
                return compared
            ::
            stack := push_stack(lhs_pop.next, compared.value)
            ip := ip + 1
        ::

        if instruction.kind == "Neq" ::
            let rhs_pop := pop_stack(stack)
            if not rhs_pop.ok ::
                return fail_state(rhs_pop.error)
            ::
            let lhs_pop := pop_stack(rhs_pop.next)
            if not lhs_pop.ok ::
                return fail_state(lhs_pop.error)
            ::
            let compared := neq_values(lhs_pop.value, rhs_pop.value)
            if not compared.ok ::
                return compared
            ::
            stack := push_stack(lhs_pop.next, compared.value)
            ip := ip + 1
        ::

        if instruction.kind == "Lt" ::
            let rhs_pop := pop_stack(stack)
            if not rhs_pop.ok ::
                return fail_state(rhs_pop.error)
            ::
            let lhs_pop := pop_stack(rhs_pop.next)
            if not lhs_pop.ok ::
                return fail_state(lhs_pop.error)
            ::
            let compared := lt_values(lhs_pop.value, rhs_pop.value)
            if not compared.ok ::
                return compared
            ::
            stack := push_stack(lhs_pop.next, compared.value)
            ip := ip + 1
        ::

        if instruction.kind == "Gt" ::
            let rhs_pop := pop_stack(stack)
            if not rhs_pop.ok ::
                return fail_state(rhs_pop.error)
            ::
            let lhs_pop := pop_stack(rhs_pop.next)
            if not lhs_pop.ok ::
                return fail_state(lhs_pop.error)
            ::
            let compared := gt_values(lhs_pop.value, rhs_pop.value)
            if not compared.ok ::
                return compared
            ::
            stack := push_stack(lhs_pop.next, compared.value)
            ip := ip + 1
        ::

        if instruction.kind == "Le" ::
            let rhs_pop := pop_stack(stack)
            if not rhs_pop.ok ::
                return fail_state(rhs_pop.error)
            ::
            let lhs_pop := pop_stack(rhs_pop.next)
            if not lhs_pop.ok ::
                return fail_state(lhs_pop.error)
            ::
            let compared := le_values(lhs_pop.value, rhs_pop.value)
            if not compared.ok ::
                return compared
            ::
            stack := push_stack(lhs_pop.next, compared.value)
            ip := ip + 1
        ::

        if instruction.kind == "Ge" ::
            let rhs_pop := pop_stack(stack)
            if not rhs_pop.ok ::
                return fail_state(rhs_pop.error)
            ::
            let lhs_pop := pop_stack(rhs_pop.next)
            if not lhs_pop.ok ::
                return fail_state(lhs_pop.error)
            ::
            let compared := ge_values(lhs_pop.value, rhs_pop.value)
            if not compared.ok ::
                return compared
            ::
            stack := push_stack(lhs_pop.next, compared.value)
            ip := ip + 1
        ::

        if instruction.kind == "Not" ::
            let popped := pop_stack(stack)
            if not popped.ok ::
                return fail_state(popped.error)
            ::
            let negated := not_value(popped.value)
            if not negated.ok ::
                return negated
            ::
            stack := push_stack(popped.next, negated.value)
            ip := ip + 1
        ::

        if instruction.kind == "Neg" ::
            let popped := pop_stack(stack)
            if not popped.ok ::
                return fail_state(popped.error)
            ::
            let negated := neg_value(popped.value)
            if not negated.ok ::
                return negated
            ::
            stack := push_stack(popped.next, negated.value)
            ip := ip + 1
        ::

        if instruction.kind == "Jump" ::
            ip := parse_i64(json.stringify(instruction.target))
        ::

        if instruction.kind == "JumpIfFalse" ::
            let popped := pop_stack(stack)
            if not popped.ok ::
                return fail_state(popped.error)
            ::
            let target := parse_i64(json.stringify(instruction.target))
            let keep_value := jump_if_false_keeps_value(function, ip, target)
            stack := popped.next
            if keep_value ::
                stack := push_stack(stack, popped.value)
            ::
            if not is_truthy(popped.value) ::
                ip := target
            ::
            if is_truthy(popped.value) ::
                ip := ip + 1
            ::
        ::

        if instruction.kind == "Pop" ::
            let popped := pop_stack(stack)
            if not popped.ok ::
                return fail_state(popped.error)
            ::
            stack := popped.next
            ip := ip + 1
        ::

        if instruction.kind == "Return" ::
            let popped := pop_stack(stack)
            if not popped.ok ::
                return fail_state("Return currently requires a value")
            ::
            return ok_state(popped.value, globals)
        ::

        if instruction.kind == "TryUnwrap" ::
            let popped := pop_stack(stack)
            if not popped.ok ::
                return fail_state(popped.error)
            ::
            if popped.value.kind == "Null" ::
                return fail_state("Tried to unwrap none")
            ::
            stack := push_stack(popped.next, popped.value)
            ip := ip + 1
        ::

        if not is_supported_instruction_kind(instruction.kind) ::
            return fail_state("unsupported instruction in native_buffer_handle_v9")
        ::
    ::

    return fail_state("function ended without Return")
::

fn execute_function(program, globals, function_index: Int, locals, active_coro, call_depth: Int) ::
    return execute_function_resume(program, globals, function_index, locals, active_coro, call_depth, 0, none, false)
::

fn main() -> Int ::
    let mode := env.get("ENKAI_RUNTIME_MODE")
    if mode == none ::
        return fail("missing ENKAI_RUNTIME_MODE")
    ::
    let input := env.get("ENKAI_RUNTIME_INPUT")
    if input == none ::
        return fail("missing ENKAI_RUNTIME_INPUT")
    ::
    let output := env.get("ENKAI_RUNTIME_OUTPUT")
    if output == none ::
        return fail("missing ENKAI_RUNTIME_OUTPUT")
    ::

    let summary := json.parse("{}")
    summary.mode := mode?
    summary.input := input?

    if mode? != "audit" ::
        summary.ok := false
        summary.supported := false
        summary.error := "unknown ENKAI_RUNTIME_MODE"
        summary.error_code := "E_RUNTIME_MODE"
        summary.error_kind := "runtime"
        return finish(output?, summary)
    ::

    let program := compiler.describe_program_file(input?)
    let entry_index := parse_i64(json.stringify(program.main_index))
    let globals_state := install_globals(program)
    if not globals_state.ok ::
        summary.ok := false
        summary.supported := false
        summary.error := globals_state.error
        summary.error_code := globals_state.error_code
        summary.error_kind := globals_state.error_kind
        return finish(output?, summary)
    ::
    let runtime_state := execute_function(program, globals_state.globals, entry_index, none, none, 0)

    if not runtime_state?.ok ::
        summary.ok := false
        summary.supported := false
        summary.error := runtime_state?.error
        summary.error_code := runtime_state?.error_code
        summary.error_kind := runtime_state?.error_kind
        if runtime_state?.globals != none ::
            summary.metrics := runtime_metrics_record(runtime_state?.globals)
        ::
        return finish(output?, summary)
    ::

    let result := summarize_result(runtime_state?.globals, runtime_state?.value)
    if not result.ok ::
        summary.ok := false
        summary.supported := false
        summary.error := result.error
        summary.error_code := result.error_code
        summary.error_kind := result.error_kind
        if result.globals != none ::
            summary.metrics := runtime_metrics_record(result.globals)
        ::
        return finish(output?, summary)
    ::

    summary.ok := true
    summary.supported := true
    summary.result_kind := result.result_kind
    summary.result := result.result
    summary.metrics := runtime_metrics_record(result.globals)
    return finish(output?, summary)
::

main()
