import std::env
import std::io

native::import "enkai_native" ::
    fn parse_i64(text: String) -> Int
    fn parse_f64(text: String) -> Float
    fn canonical_builtin_global_name(text: String) -> String
    fn qualified_name_tail(text: String) -> String
    fn runtime_json_parse_value(text: String) -> String
    fn runtime_json_stringify_value(value: String) -> String
    fn runtime_stable_domain_hash(text: String) -> Int
    fn runtime_mix_rng_seed(world_seed: Int, stream_id: Int, domain_id: Int) -> Int
    fn runtime_rng_next_state(state: Int) -> Int
    fn runtime_rng_state_to_float(state: Int) -> Float
    fn runtime_rng_state_to_int(state: Int, upper: Int) -> Int
    fn runtime_ffi_invoke(payload: String) -> String
::

policy default ::
    allow env
    allow fs
    allow io
::

fn fail(message: String) -> Int ::
    io.stderr_write_text(message)
    io.stderr_write_text("\n")
    return 1
::

fn write_summary(output: String, summary) -> Bool ::
    return io.write_text(output, json.stringify(summary))
::

fn finish(output: String, summary) -> Int ::
    if not write_summary(output, summary) ::
        return fail("failed to write runtime summary")
    ::
    if summary.ok ::
        return 0
    ::
    return 1
::

fn int_value(value: Int) ::
    let out := json.parse("{}")
    out.kind := "Int"
    out.value := value
    return out
::

fn float_value(value: Float) ::
    let out := json.parse("{}")
    out.kind := "Float"
    out.value := value
    return out
::

fn string_value(value: String) ::
    let out := json.parse("{}")
    out.kind := "String"
    out.value := value
    return out
::

fn bool_value(value: Bool) ::
    let out := json.parse("{}")
    out.kind := "Bool"
    out.value := value
    return out
::

fn null_value() ::
    let out := json.parse("{}")
    out.kind := "Null"
    out.value := none
    return out
::

fn function_value(function_index: Int) ::
    let out := json.parse("{}")
    out.kind := "Function"
    out.function_index := function_index
    return out
::

fn closure_value(function_index: Int, arity: Int, captures) ::
    let out := json.parse("{}")
    out.kind := "Closure"
    out.function_index := function_index
    out.arity := arity
    out.captures := captures
    return out
::

fn native_function_value(library: String, name: String, signature) ::
    let out := json.parse("{}")
    out.kind := "NativeFunction"
    out.library := library
    out.name := name
    out.signature := signature
    return out
::

fn builtin_native_function(name: String) ::
    return native_function_value("__runtime_builtin__", name, none)
::

fn record_value(fields) ::
    let out := json.parse("{}")
    out.kind := "Record"
    out.fields := fields
    return out
::

fn list_value(items) ::
    let out := json.parse("{}")
    out.kind := "List"
    out.items := items
    return out
::

fn ok_state(value, globals) ::
    let out := json.parse("{}")
    out.ok := true
    out.supported := true
    out.yielded := false
    out.continuation := none
    out.value := value
    out.globals := globals
    return out
::

fn runtime_error_code(message: String) -> String ::
    if message == "Division by zero" ::
        return "E_RUNTIME_DIVISION_BY_ZERO"
    ::
    if message == "Modulo by zero" ::
        return "E_RUNTIME_MODULO_BY_ZERO"
    ::
    if message == "list index out of bounds" ::
        return "E_RUNTIME_INDEX_OUT_OF_RANGE"
    ::
    if message == "Index out of range" ::
        return "E_RUNTIME_INDEX_OUT_OF_RANGE"
    ::
    if message == "Tried to unwrap none" ::
        return "E_RUNTIME_UNWRAP_NONE"
    ::
    if message == "chan.recv would block: no ready sender in self-host runtime" ::
        return "E_RUNTIME_CHANNEL_WOULD_BLOCK"
    ::
    if message == "task.join expects TaskHandle" ::
        return "E_RUNTIME_INVALID_TASK_HANDLE"
    ::
    if message == "task handle is not registered" ::
        return "E_RUNTIME_INVALID_TASK_HANDLE"
    ::
    if message == "Call arity mismatch in audited subset" ::
        return "E_RUNTIME_ARITY_MISMATCH"
    ::
    if message == "Call expects Function, Closure, or NativeFunction value" ::
        return "E_RUNTIME_CALL_TARGET"
    ::
    if message == "stack underflow" ::
        return "E_RUNTIME_STACK_UNDERFLOW"
    ::
    if message == "Stack underflow" ::
        return "E_RUNTIME_STACK_UNDERFLOW"
    ::
    if message == "Field access expects record-like value" ::
        return "E_RUNTIME_FIELD_ACCESS"
    ::
    if message == "Unknown field" ::
        return "E_RUNTIME_FIELD_ACCESS"
    ::
    if message == "unsupported runtime builtin" ::
        return "E_RUNTIME_UNSUPPORTED"
    ::
    if message == "unsupported native function in self-host runtime" ::
        return "E_RUNTIME_UNSUPPORTED"
    ::
    return "E_RUNTIME_ERROR"
::

fn fail_state(message: String) ::
    let out := json.parse("{}")
    out.ok := false
    out.supported := false
    out.yielded := false
    out.continuation := none
    out.error := message
    out.error_code := runtime_error_code(message)
    out.error_kind := "runtime"
    out.globals := none
    return out
::

fn fail_state_with_globals(message: String, globals) ::
    let out := fail_state(message)
    out.globals := globals
    return out
::

fn yield_state(value, globals, locals, stack, ip: Int, function_index: Int) ::
    let out := ok_state(value, globals)
    out.yielded := true
    out.locals := locals
    out.stack := stack
    out.ip := ip
    out.function_index := function_index
    out.continuation := none
    return out
::

fn push_stack(head, value) ::
    let node := json.parse("{}")
    node.value := value
    node.next := head
    return node
::

fn pop_stack(head) ::
    let out := json.parse("{}")
    if head == none ::
        out.ok := false
        out.error := "stack underflow"
        return out
    ::
    out.ok := true
    out.value := head?.value
    out.next := head?.next
    return out
::

fn load_global(head, slot: Int) ::
    let node := head
    while node != none ::
        if node?.slot == slot ::
            return node?.value
        ::
        node := node?.next
    ::
    return none
::

fn store_global(head, slot: Int, value) ::
    let node := head
    while node != none ::
        if node?.slot == slot ::
            node.value := value
            return head
        ::
        node := node?.next
    ::
    let entry := json.parse("{}")
    entry.slot := slot
    entry.value := value
    entry.next := head
    return entry
::

fn load_local(head, slot: Int) ::
    let node := head
    while node != none ::
        if node?.slot == slot ::
            return node?.value
        ::
        node := node?.next
    ::
    return none
::

fn store_local(head, slot: Int, value) ::
    let node := head
    while node != none ::
        if node?.slot == slot ::
            node.value := value
            return head
        ::
        node := node?.next
    ::
    let entry := json.parse("{}")
    entry.slot := slot
    entry.value := value
    entry.next := head
    return entry
::

