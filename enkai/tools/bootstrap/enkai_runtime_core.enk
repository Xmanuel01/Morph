fn runtime_table_lookup(head, id: Int) ::
    let node := head
    while node != none ::
        if node?.id == id ::
            return node?.value
        ::
        node := node?.next
    ::
    return none
::

fn runtime_table_store(head, id: Int, value) ::
    let node := head
    while node != none ::
        if node?.id == id ::
            node.value := value
            return head
        ::
        node := node?.next
    ::
    let entry := json.parse("{}")
    entry.id := id
    entry.value := value
    entry.next := head
    return entry
::

fn next_runtime_id(globals, slot: Int) -> Int ::
    let value := load_global(globals, slot)
    if value == none ::
        return 1
    ::
    if value?.kind == "Null" ::
        return 1
    ::
    if value?.kind == "Int" ::
        return parse_i64(json.stringify(value?.value))
    ::
    return 1
::

fn metric_value(globals, slot: Int) -> Int ::
    let value := load_global(globals, slot)
    if value == none ::
        return 0
    ::
    if value?.kind == "Int" ::
        return parse_i64(json.stringify(value?.value))
    ::
    return 0
::

fn metric_inc(globals, slot: Int, amount: Int) ::
    let next_value := metric_value(globals, slot) + amount
    return store_global(globals, slot, int_value(next_value))
::

fn metric_max(globals, slot: Int, value: Int) ::
    let current := metric_value(globals, slot)
    if value > current ::
        return store_global(globals, slot, int_value(value))
    ::
    return globals
::

fn runtime_metrics_record(globals) ::
    let out := json.parse("{}")
    out.execute_calls := metric_value(globals, metric_exec_calls_slot())
    out.execute_max_depth := metric_value(globals, metric_exec_max_depth_slot())
    out.json_nodes := metric_value(globals, metric_json_nodes_slot())
    out.json_max_depth := metric_value(globals, metric_json_max_depth_slot())
    out.snapshot_calls := metric_value(globals, metric_snapshot_calls_slot())
    out.queue_sort_calls := metric_value(globals, metric_queue_sort_calls_slot())
    out.queue_sort_items := metric_value(globals, metric_queue_sort_items_slot())
    out.entity_snapshot_calls := metric_value(globals, metric_entity_snapshot_calls_slot())
    out.entity_snapshot_items := metric_value(globals, metric_entity_snapshot_items_slot())
    out.list_append_calls := metric_value(globals, metric_list_append_calls_slot())
    out.list_append_steps := metric_value(globals, metric_list_append_steps_slot())
    out.tasks_spawned := metric_value(globals, metric_tasks_spawned_slot())
    out.task_joins := metric_value(globals, metric_task_joins_slot())
    out.task_sleeps := metric_value(globals, metric_task_sleeps_slot())
    out.channel_sends := metric_value(globals, metric_channel_sends_slot())
    out.channel_recvs := metric_value(globals, metric_channel_recvs_slot())
    return out
::

fn runtime_cleanup_globals(globals) ::
    if globals == none ::
        return none
    ::
    globals := store_global(globals, world_table_slot(), null_value())
    globals := store_global(globals, coroutine_table_slot(), null_value())
    globals := store_global(globals, spatial_table_slot(), null_value())
    globals := store_global(globals, agent_env_table_slot(), null_value())
    globals := store_global(globals, snn_table_slot(), null_value())
    globals := store_global(globals, task_table_slot(), null_value())
    globals := store_global(globals, channel_table_slot(), null_value())
    return globals
::

fn world_state_record(globals, world_id: Int) ::
    let table := load_global(globals, world_table_slot())
    if table == none ::
        return none
    ::
    return runtime_table_lookup(table?, world_id)
::

fn store_world_state_record(globals, world_id: Int, state) ::
    let table := load_global(globals, world_table_slot())
    let next_table := runtime_table_store(table, world_id, state)
    return store_global(globals, world_table_slot(), next_table)
::

