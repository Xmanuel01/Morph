    out.time := event_entry.time
    out.seq := event_entry.seq
    out.event := event_entry.event
    return record_value(store_named_field(store_named_field(store_named_field(none, "event", event_entry.event), "seq", int_value(event_entry.seq)), "time", float_value(event_entry.time)))
::

fn event_record_time(record) -> Float ::
    let value := load_named_field(record.fields, "time")
    if value == none ::
        return 0.0
    ::
    if value?.kind == "Float" ::
        return parse_f64(json.stringify(value?.value))
    ::
    if value?.kind == "Int" ::
        return parse_f64(json.stringify(value?.value))
    ::
    return 0.0
::

fn event_record_seq(record) -> Int ::
    let value := load_named_field(record.fields, "seq")
    if value == none ::
        return 0
    ::
    if value?.kind == "Int" ::
        return parse_i64(json.stringify(value?.value))
    ::
    if value?.kind == "Float" ::
        return parse_i64(json.stringify(value?.value))
    ::
    return 0
::

fn event_record_event(record) ::
    let value := load_named_field(record.fields, "event")
    if value == none ::
        return null_value()
    ::
    return value?
::

