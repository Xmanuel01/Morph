        spatial_state.value.positions := removed.items
        let next_globals := store_spatial_state_record(spatial_state.globals, spatial_state.spatial_id, spatial_state.value)
        return ok_state(bool_value(removed.removed), next_globals)
    ::
    if name == "spatial.radius" ::
        let index_state := require_kind_arg(args, 0, "SpatialIndex", "spatial.radius expects SpatialIndex")
        if not index_state.ok ::
            return index_state
        ::
        let spatial_state := require_spatial_state(globals, index_state.value, "spatial.radius expects SpatialIndex")
        if not spatial_state.ok ::
            return spatial_state
        ::
        let x := require_float_arg(args, 1, "spatial.radius expects x")
        if not x.ok ::
            return x
        ::
        let y := require_float_arg(args, 2, "spatial.radius expects y")
        if not y.ok ::
            return y
        ::
        let radius := require_float_arg(args, 3, "spatial.radius expects radius")
        if not radius.ok ::
            return radius
        ::
        let radius_value := parse_f64(json.stringify(radius.value))
        let x_value := parse_f64(json.stringify(x.value))
        let y_value := parse_f64(json.stringify(y.value))
        let radius_sq := radius_value * radius_value
        let matches := none
        let node := spatial_state.value.positions
        while node != none ::
            let dx := parse_f64(json.stringify(node?.x)) - x_value
            let dy := parse_f64(json.stringify(node?.y)) - y_value
            let dist_sq := dx * dx + dy * dy
            if dist_sq <= radius_sq ::
                matches := insert_spatial_result_sorted(matches, node?.id, dist_sq)
            ::
            node := node?.next
        ::
        return ok_state(spatial_sorted_ids(matches), none)
    ::
    if name == "spatial.nearest" ::
        let index_state := require_kind_arg(args, 0, "SpatialIndex", "spatial.nearest expects SpatialIndex")
        if not index_state.ok ::
            return index_state
        ::
        let spatial_state := require_spatial_state(globals, index_state.value, "spatial.nearest expects SpatialIndex")
        if not spatial_state.ok ::
            return spatial_state
        ::
        let x := require_float_arg(args, 1, "spatial.nearest expects x")
        if not x.ok ::
            return x
        ::
        let y := require_float_arg(args, 2, "spatial.nearest expects y")
        if not y.ok ::
            return y
        ::
        let x_value := parse_f64(json.stringify(x.value))
        let y_value := parse_f64(json.stringify(y.value))
        let best_id := none
        let best_dist := 0.0
        let node := spatial_state.value.positions
        while node != none ::
            let dx := parse_f64(json.stringify(node?.x)) - x_value
            let dy := parse_f64(json.stringify(node?.y)) - y_value
            let dist_sq := dx * dx + dy * dy
            if best_id == none ::
                best_id := node?.id
                best_dist := dist_sq
            ::
            else ::
                if dist_sq < best_dist ::
                    best_id := node?.id
                    best_dist := dist_sq
                ::
                if dist_sq == best_dist ::
                    if node?.id < best_id? ::
                        best_id := node?.id
                        best_dist := dist_sq
                    ::
                ::
            ::
            node := node?.next
        ::
        if best_id == none ::
            return ok_state(null_value(), none)
        ::
        return ok_state(int_value(best_id?), none)
    ::
    if name == "spatial.occupancy" ::
        let index_state := require_kind_arg(args, 0, "SpatialIndex", "spatial.occupancy expects SpatialIndex")
        if not index_state.ok ::
            return index_state
        ::
        let spatial_state := require_spatial_state(globals, index_state.value, "spatial.occupancy expects SpatialIndex")
        if not spatial_state.ok ::
            return spatial_state
        ::
        let min_x := require_float_arg(args, 1, "spatial.occupancy expects min_x")
        if not min_x.ok ::
            return min_x
        ::
        let min_y := require_float_arg(args, 2, "spatial.occupancy expects min_y")
        if not min_y.ok ::
            return min_y
        ::
        let max_x := require_float_arg(args, 3, "spatial.occupancy expects max_x")
        if not max_x.ok ::
            return max_x
        ::
        let max_y := require_float_arg(args, 4, "spatial.occupancy expects max_y")
        if not max_y.ok ::
            return max_y
        ::
        let count := 0
        let node := spatial_state.value.positions
        while node != none ::
            let pos_x := node?.x
            let pos_y := node?.y
            if pos_x >= min_x.value ::
                if pos_x <= max_x.value ::
                    if pos_y >= min_y.value ::
                        if pos_y <= max_y.value ::
                            count := count + 1
                        ::
                    ::
                ::
            ::
            node := node?.next
        ::
        return ok_state(int_value(count), none)
    ::
    return fail_state("unsupported spatial builtin")
::

