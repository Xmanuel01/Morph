fn sync_agent_world_snapshot(globals, env_state, agent_id: Int, agent_record) ::
    let world_state := require_world_state(globals, sim_world_handle(parse_i64(json.stringify(env_state.world_id))), "agent env world handle is not registered")
    if not world_state.ok ::
        return world_state
