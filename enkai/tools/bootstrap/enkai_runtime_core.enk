fn store_sparse_vector_entry(head, index: Int, value: Float) ::
    let node := head
    while node != none ::
        if node?.index == index ::
            if value == 0.0 ::
                node.value := 0.0
            ::
            else ::
                node.value := value
            ::
            return head
        ::
        node := node?.next
    ::
    if value == 0.0 ::
        return head
    ::
    return push_sparse_vector_entry(head, index, value)
::

