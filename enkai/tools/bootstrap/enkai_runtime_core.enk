fn insert_spatial_result_sorted(head, id: Int, dist_sq: Float) ::
    let entry := json.parse("{}")
    entry.id := id
    entry.dist_sq := dist_sq
    entry.next := none
    if head == none ::
        return entry
    ::
    if dist_sq < head?.dist_sq ::
        entry.next := head
        return entry
    ::
    if dist_sq == head?.dist_sq ::
        if id < head?.id ::
            entry.next := head
            return entry
        ::
    ::
    let node := head
    while node?.next != none ::
        let before := false
        if dist_sq < node?.next?.dist_sq ::
            before := true
        ::
        if dist_sq == node?.next?.dist_sq ::
            if id < node?.next?.id ::
                before := true
            ::
        ::
        if before ::
            entry.next := node?.next
            node.next := entry
            return head
        ::
        node := node?.next
    ::
    node.next := entry
    return head
::

